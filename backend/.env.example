NODE_ENV=development
PORT=3000

# PDFs & uploads (movement PDFs under UPLOAD_ROOT/movimientos/)
# PUBLIC_APP_URL = base URL used in Movimiento.pdfUrl (no trailing slash)
PUBLIC_APP_URL=http://localhost:3000
# UPLOAD_ROOT=/var/app/uploads
# Comma-separated origins, or omit for reflect default (allow all in dev)
# CORS_ORIGIN=https://app.example.com,https://admin.example.com

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=ose_inventory

# TypeORM (set false in production; use migrations)
TYPEORM_SYNC=true

# JWT
JWT_SECRET=change-me-in-production-min-32-chars-long
JWT_EXPIRES_IN=7d

# Optional: first admin seed (npm run seed)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=Administrator

# Password reset email (link points to FRONTEND_URL)
FRONTEND_URL=http://localhost:5173
# If true or SMTP not set, reset link is only logged on the server (dev)
MAIL_LOG_ONLY=true
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com
